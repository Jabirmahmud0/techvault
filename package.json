    "packages/*"
  ],
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "firebase": "^12.9.0",
    "firebase-admin": "^10.3.0",
    "jest-environment-jsdom": "30.3.0",
    "next": "16.2.3",
    "nodemailer": "8.0.5"
